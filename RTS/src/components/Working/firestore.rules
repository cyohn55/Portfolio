// Firestore security rules for the RTS global leaderboard AND the multiplayer
// peer-to-peer signaling/matchmaking collections.
//
// HOW TO APPLY:
//   Firebase console -> Firestore Database -> Rules tab -> paste -> Publish.
//   (Project: rts-leader-board.)
//
//   RECOMMENDED (auto-cleanup): enable a Firestore TTL policy on the `createdAt`
//   field for the `rooms` and `matchmaking` collections (Firestore -> TTL) so
//   abandoned signaling docs expire automatically. The client also best-effort
//   deletes its own rooms on leave, but a TTL guarantees nothing lingers.
//
// SECURITY MODEL:
//   The Firebase web apiKey ships in the client bundle, so the database is
//   reachable by anyone. These rules are the actual access control:
//     * Anyone may READ the leaderboard (it is public by design).
//     * Anyone may CREATE a score, but only if the document is well-formed and
//       within sane bounds — this blocks junk rows and absurd scores.
//     * No client may ever UPDATE or DELETE — the board cannot be tampered with
//       or wiped from the browser.
//
//   This stops tampering and obvious garbage. It does NOT prove a score was
//   honestly earned (a determined user can still POST a within-bounds fake),
//   because a static site has no trusted server to validate the match. That
//   trade-off was accepted for the portfolio build; moving validation
//   server-side would require a Cloud Function / Worker.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /scores/{scoreId} {
      allow read: if true;
      allow create: if isValidScore(request.resource.data);
      allow update, delete: if false;
    }

    // --- Multiplayer signaling + matchmaking ---
    //
    // These collections broker WebRTC connections between two browsers: a room/
    // ticket document holds the SDP offer/answer, and its candidate subcollections
    // hold trickled ICE candidates. The payloads are ephemeral and non-sensitive
    // (no credentials, no game state — just connection-setup data), and there is
    // no auth on a static site, so full CRUD is permitted. The size guard blocks
    // obviously-abusive oversized writes; the createdAt TTL (see header) reclaims
    // abandoned docs. UPDATE is required so a guest can write its answer / claim a
    // ticket; DELETE so a host can clean up its own room on leave.

    match /rooms/{roomId} {
      // Reads/deletes carry no incoming document and are unconditional; only
      // writes are shape-guarded. The guard MUST live on the write rules alone:
      // `request.resource` is undefined on a read (referencing it errors, which
      // Firestore evaluates as deny), so a combined `read, create, ...` rule that
      // touches request.resource silently denies every read.
      allow read, delete: if true;
      allow create, update: if isSaneSignalingWrite();
      // Per-side ICE candidate streams (hostCandidates / guestCandidates).
      match /{candidateSet}/{candidateId} {
        allow read, create, delete: if true;
      }
    }

    match /matchmaking/{ticketId} {
      allow read, delete: if true;
      allow create, update: if isSaneSignalingWrite();
      match /{candidateSet}/{candidateId} {
        allow read, create, delete: if true;
      }
    }

    // Light shape guard on signaling WRITES only (create/update), where
    // request.resource is always the incoming document. Caps the top-level field
    // count (a room/ticket has ~4 fields: offer, answer, status, createdAt) to
    // reject obviously-malformed bulk writes. Field VALUE sizes are intentionally
    // not restricted — an SDP blob is one large legitimate string.
    function isSaneSignalingWrite() {
      return request.resource.data.size() <= 16;
    }

    // Mirrors the client-side contract in leaderboard.ts (isWellFormedEntry +
    // validateName bounds): exactly these five fields, correct types, and
    // ranges that keep the board sane. SCORE_CEILING is a generous upper bound
    // — comfortably above any honest match total, low enough to reject an
    // obviously bogus submission.
    function isValidScore(data) {
      return data.keys().hasOnly(['name', 'score', 'dateMs', 'result', 'matchTimeMs'])
        && data.name is string
        && data.name.size() >= 2
        && data.name.size() <= 16
        && data.score is number
        && data.score >= 0
        && data.score <= 100000
        && data.dateMs is number
        && data.matchTimeMs is number
        && data.matchTimeMs >= 0
        && (data.result == 'victory' || data.result == 'defeat');
    }
  }
}
